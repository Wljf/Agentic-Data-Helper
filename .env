FLASK_ENV=development
FLASK_DEBUG=True

# SQLite（可选，config 保留字段；数仓与验证数据已改为写入 Doris）
SQLITE_DB_URL=sqlite:///./data_agent.db

# Apache Doris：FE 查询端口 9030；初始化脚本需建表/写入权限，详见 docs/doris-setup.md
# 示例：mysql+pymysql://user:password@127.0.0.1:9030/data_agent
DORIS_DB_URL=

# 重复执行 python -m data_mock.init_warehouse 前是否先 TRUNCATE 四张数仓表（true/false）
# INIT_WAREHOUSE_TRUNCATE=false

# LLM API（支持 OpenAI 或 DeepSeek 等 OpenAI 兼容接口）
# 使用 DeepSeek：OPENAI_API_BASE=https://api.deepseek.com/v1，OPENAI_MODEL=deepseek-chat
# 使用 OpenAI：OPENAI_API_BASE=，OPENAI_MODEL=gpt-4o-mini
OPENAI_API_KEY=sk-e8a677dac1254ad28a5fea0acef64576
OPENAI_API_BASE=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-chat

# ChromaDB 本地持久化路径
CHROMA_PERSIST_DIR=./chroma_db

